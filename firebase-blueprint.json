{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the MERCAPLY platform (buyer, seller, or admin).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["buyer", "seller", "admin"] },
        "region": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isVerified": { "type": "boolean" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A product listed on the marketplace.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "minOrder": { "type": "number" },
        "category": { "type": "string" },
        "subcategory": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "region": { "type": "string" },
        "stock": { "type": "number" },
        "unit": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "views": { "type": "number" }
      },
      "required": ["id", "sellerId", "title", "price", "category", "images", "region", "stock", "isActive"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a buyer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "processing", "shipped", "delivered", "cancelled", "refunded"] },
        "paymentMethod": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "buyerId", "sellerId", "items", "totalAmount", "status", "paymentMethod", "createdAt"]
    },
    "Store": {
      "title": "Store",
      "description": "A seller's store profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "banner": { "type": "string" },
        "description": { "type": "string" },
        "region": { "type": "string" },
        "rating": { "type": "number" },
        "totalSales": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "categories": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "ownerId", "name", "region", "isVerified"]
    },
    "Review": {
      "title": "Review",
      "description": "A review left by a buyer for a product.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "buyerId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "productId", "buyerId", "rating", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" }
      },
      "required": ["id", "conversationId", "senderId", "content", "timestamp", "isRead"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A conversation between two users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "participants", "updatedAt"]
    },
    "Category": {
      "title": "Category",
      "description": "A product category.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "icon": { "type": "string" },
        "subcategories": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "slug"]
    },
    "Promotion": {
      "title": "Promotion",
      "description": "A promotion for a product.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "productId": { "type": "string" },
        "discountPercent": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "sellerId", "productId", "discountPercent", "startDate", "endDate"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "type", "message", "isRead", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Collection of users."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Collection of products."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Collection of orders."
    },
    "/stores/{storeId}": {
      "schema": { "$ref": "#/entities/Store" },
      "description": "Collection of stores."
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Collection of reviews."
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Collection of messages."
    },
    "/conversations/{conversationId}": {
      "schema": { "$ref": "#/entities/Conversation" },
      "description": "Collection of conversations."
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Collection of categories."
    },
    "/promotions/{promotionId}": {
      "schema": { "$ref": "#/entities/Promotion" },
      "description": "Collection of promotions."
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "Collection of notifications."
    }
  }
}
